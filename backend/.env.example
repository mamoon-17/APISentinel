# Server
PORT=3000
DATABASE_URI=your_database_uri

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend
FRONTEND_BASE_URL=http://localhost:8080

# Session signing secret
SESSION_SECRET=replace_with_a_long_random_secret

# LLM-powered schema analysis (optional)
# Set LLM_ENABLED=true to activate AI-assisted violation detection
# GITHUB_MODELS_TOKEN is your GitHub personal access token with Models access
# If not set, the user's connected GitHub token is used automatically
LLM_ENABLED=false
GITHUB_MODELS_TOKEN=

# Optional spec file storage (Supabase)
# When set, uploaded specs are stored in Supabase in addition to MongoDB.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Ops: keep-alive ping (opt-in)
# Pings /health on an interval to prevent idle instances from sleeping.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_URL=http://localhost:3000/health
KEEP_ALIVE_INTERVAL_MINUTES=10

# Ops: MongoDB Atlas heartbeat (opt-in)
# Writes a heartbeat doc periodically to keep Atlas awake.
ATLAS_HEARTBEAT_ENABLED=false
ATLAS_URI=
ATLAS_DB=apisentinel
ATLAS_HEARTBEAT_COLLECTION=__heartbeat__
ATLAS_HEARTBEAT_INTERVAL_HOURS=24
