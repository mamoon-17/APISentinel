@baseUrl = http://localhost:3000

# ------------------------------------------------------------
# APISentinel Workstream 3 tests (spec lifecycle) for VS Code REST Client
# Extension: humao.rest-client
#
# How to use:
# 1) Start backend server (npm run dev in backend).
# 2) Run requests one by one with "Send Request".
# 3) Copy IDs from responses into variables below when needed.
# ------------------------------------------------------------

# Default from sample title "User Service API" -> user-service-api
@specId = user-service-api
# IMPORTANT: versionId is the DB id from GET /specs/:id/versions (not semantic version like v1.0.1)
@versionId =
@repoId =
@sessionCookie =

###
# 1) Upload OpenAPI spec (valid JSON)
# Expected: 201 and response.version with id/specId/version/status
# Frontend parity: uploading a valid .json/.yaml file in Repository Detail should succeed.
POST {{baseUrl}}/specs/upload
Content-Type: application/json

{
  "fileName": "sample-user-api.json",
  "content": "{\"openapi\":\"3.0.0\",\"info\":{\"title\":\"User Service API\",\"version\":\"v1.0.0\"},\"paths\":{\"/users\":{\"get\":{\"summary\":\"List users\"}}}}"
}

###
# 2) Upload newer version for same API title (auto inactivates previous active)
# Expected: 201 and new active version
POST {{baseUrl}}/specs/upload
Content-Type: application/json

{
  "fileName": "sample-user-api-v101.json",
  "content": "{\"openapi\":\"3.0.0\",\"info\":{\"title\":\"User Service API\",\"version\":\"v1.0.1\"},\"paths\":{\"/users\":{\"get\":{\"summary\":\"List users\"}},\"/users/{id}\":{\"get\":{\"summary\":\"Get user\"}}}}"
}

###
# 3) List specs
# Expected: 200 with grouped specs summary
GET {{baseUrl}}/specs

###
# 4) List versions for one spec
# Paste spec id from GET /specs into @specId above
GET {{baseUrl}}/specs/{{specId}}/versions

###
# 5) Delete a spec version by version id
# Paste versions[n].id from GET /specs/:id/versions into @versionId above
# Expected: 204 if deletable
DELETE {{baseUrl}}/specs/versions/{{versionId}}

###
# 6) Upload invalid OpenAPI payload
# Expected: 400 with code SPEC_PARSE_FAILED
# Frontend parity: uploading malformed/invalid file should show error message (no spec created).
POST {{baseUrl}}/specs/upload
Content-Type: application/json

{
  "fileName": "invalid-spec.json",
  "content": "not a valid openapi document"
}

###
# 7) Repository inconsistencies (fixture-backed)
# Expected: 200 with inconsistencies array
# Tip: try repo-1, repo-2, repo-5
GET {{baseUrl}}/repositories/repo-2/inconsistencies?specId={{specId}}

###
# 8) Repository inconsistencies without explicit specId
# Expected: 400 with SPEC_SELECTION_REQUIRED
GET {{baseUrl}}/repositories/repo-1/inconsistencies

###
# 9) Spec violations for one spec against a repository snapshot
# Requires authenticated session + linked GitHub account.
# Paste repo id from GET /auth/repositories and session cookie from browser.
GET {{baseUrl}}/specs/{{specId}}/violations?repositoryId={{repoId}}
Cookie: api_sentinel_session={{sessionCookie}}
